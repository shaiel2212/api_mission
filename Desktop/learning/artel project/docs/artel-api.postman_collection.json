            "value": "{{adminApiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"contacted\",\n  \"priority\": \"high\",\n  \"assignedTo\": 1,\n  \"nextFollowUpAt\": \"2026-04-18T09:00:00.000Z\",\n  \"note\": \"Called customer and scheduled follow-up.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/leads/{{leadId}}",
          "host": [
