PORT=3001
NODE_ENV=development

# אופציונלי: נתיב ל־build של הקליינט (למשל ../client/dist) — משרת את ה־SPA ומונע 404 אחרי ריענון ב־/projects וכו׳
# CLIENT_DIST=../client/dist

# MySQL (matches docker-compose.yml defaults)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=artel
DB_USER=artel
DB_PASSWORD=artel_dev

# Comma-separated origins for CORS (no spaces)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Duplicate lead: same phone blocked within this many minutes
DUPLICATE_LEAD_WINDOW_MINUTES=15

# Enable schema ALTER during db:init (development only)
DB_SYNC_ALTER=false

# Protect internal admin endpoints (optional if staff use browser login only)
ADMIN_API_KEY=change-me

# Browser admin session (min 16 chars); required for POST /api/auth/login
SESSION_SECRET=change-me-long-random-string
# Optional session lifetime in ms (default 7 days)
SESSION_MAX_AGE_MS=604800000

# --- Marketing Hub: OAuth (official APIs) ---
# Google Analytics (GA4) — OAuth client + redirect must match Google Cloud Console
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/google_analytics/callback

# Instagram via Facebook Login — App + redirect in Meta Developer Console
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/instagram/callback

# TikTok for Business / Login Kit + Marketing scopes (configure in TikTok Developer Portal)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_OAUTH_REDIRECT_URI=http://localhost:3001/api/integrations/tiktok/callback

# HMAC secret for OAuth state (min 16 chars recommended in production)
INTEGRATION_STATE_SECRET=change-me-long-random-string

# אחסון מוצפן של access/refresh tokens (OAuth). בפרודקשן: מומלץ 32 בתים base64/hex
# (למשל: openssl rand -base64 32)
TOKENS_ENCRYPTION_KEY=

# After OAuth, browser redirects here (query params: integration=success|error)
INTEGRATION_OAUTH_FRONTEND_REDIRECT=http://localhost:5173/admin?tab=marketing

# Hourly: sync metrics + insights + automation rules
MARKETING_SYNC_CRON_ENABLED=false
# If true without full sync cron: run automation rules hourly only
MARKETING_AUTOMATION_CRON_ENABLED=false

# Optional: POST JSON when automation rule fires
AUTOMATION_WEBHOOK_URL=
